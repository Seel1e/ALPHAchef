# Copy to .env and fill in real values before running.

# ── PostgreSQL (ALPHAchef data DB) ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alphachef
DB_USER=alphachef
DB_PASSWORD=alphachef_pass

# ── Portfolio ─────────────────────────────────────────────────────────────────
# Comma-separated list of tickers to ingest and model
TICKERS=SPY,QQQ,TLT,GLD,VNQ,XLE,XLF,EEM
START_DATE=2010-01-01

# ── Model hyper-parameters ────────────────────────────────────────────────────
N_SIMULATIONS=100000
HORIZON_DAYS=252
JUMP_LAMBDA=5.0
JUMP_MU=-0.02
JUMP_SIGMA=0.05

# ── PySpark ───────────────────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_EXECUTOR_MEMORY=4g
SPARK_DRIVER_MEMORY=4g
